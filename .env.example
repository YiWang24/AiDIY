# =================================================================
# AiDIY Environment Variables
# =================================================================
# This site runs entirely on Vercel: static Docusaurus build + serverless
# functions under /api. All persistent state lives in Neon (Vercel Postgres).
#
# For local dev:
#   cp .env.example .env.local
#   fill in DATABASE_URL + GLM_API_KEY
#   npm run db:migrate     # one-time, creates tables in Neon
#   npm run ingest         # embed docs into kb_chunks_glm
#   vercel dev             # runs api/* + Docusaurus together
#
# In production these are injected automatically by Vercel (Neon Marketplace
# integration provides DATABASE_URL; the rest are set in the Vercel dashboard).
# =================================================================

# -----------------------------------------------------------------
# Neon (Vercel Postgres) — injected by Vercel Marketplace integration
# -----------------------------------------------------------------

# Pooled HTTP-driver connection string. Required by all serverless functions.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# (Optional) Direct, unpooled connection — used by migrations + ingestion only.
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------
# GLM (Zhipu BigModel) — OpenAI-compatible endpoint
# -----------------------------------------------------------------

# API key from https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=your_glm_api_key_here

# Base URL — almost never needs to change.
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Chat completion model used by api/chat.ts
GLM_CHAT_MODEL=glm-4.7

# Embedding model used by lib/ai/embed.ts (must produce GLM_EMBED_DIM vectors).
GLM_EMBED_MODEL=embedding-3

# Embedding dimensionality. Must match the `vector(N)` declaration in
# lib/db/schema.sql. Changing this requires a re-ingestion + schema migration.
GLM_EMBED_DIM=2048

# -----------------------------------------------------------------
# Frontend (Docusaurus build-time)
# -----------------------------------------------------------------

# Public-facing URL of the parent portfolio (used by the navbar link).
FRONTEND_URL=https://www.yiw.me
